{
  "name": "@galactica-net/overcast",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://overcast.fi/",
  "packageManager": "yarn@4.13.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Galactica-corp/overcast.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "@aztec/l1-contracts": "git+https://github.com/AztecProtocol/l1-contracts.git#v4.0.0-devnet.2-patch.1"
  },
  "scripts": {
    "lint": "yarn lint:eslint && yarn format:check",
    "lint:eslint": "eslint .",
    "lint:solidity": "node scripts/solhint-if-present.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "compile:private-stablecoin": "yarn workspace @galactica-net/overcast-private-stablecoin compile",
    "codegen:private-stablecoin": "yarn workspace @galactica-net/overcast-private-stablecoin codegen",
    "test:private-stablecoin": "yarn workspace @galactica-net/overcast-private-stablecoin test",
    "test:private-stablecoin:e2e": "yarn workspace @galactica-net/overcast-private-stablecoin test:js:e2e",
    "test:private-stablecoin:bridge-e2e": "yarn workspace @galactica-net/overcast-private-stablecoin test:js:bridge-e2e",
    "test:bridge-tx-mcp": "yarn workspace @galactica-net/overcast-bridge-tx-mcp test"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.2",
    "solhint": "^5.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
